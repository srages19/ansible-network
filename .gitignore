# Ignore plain text credential files
group_vars/*
host_vars/*

# Allow example templates
!group_vars/*.example

# Allow encrypted vault files
!group_vars/*_vault.yml
!host_vars/*_vault.yml

# Allow non-credential group_vars
!group_vars/iosxr.yml
!group_vars/iosxe.yml

# Other ignores
*.retry
*.log
*.bak

# Exclude inventory - contains hostnames
inventory/hosts.ini

# Exclude vars directory - contains site specific data
vars/
