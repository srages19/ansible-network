# ==========================================
# CREDENTIALS AND SENSITIVE DATA
# ==========================================

# Ignore all group_vars contents
group_vars/*

# Allow example templates through
!group_vars/*.example

# Allow subdirectories through so examples inside them work
!group_vars/iosxr/
!group_vars/iosxe/
!group_vars/all/

# But ignore everything inside those subdirectories
group_vars/iosxr/*
group_vars/iosxe/*
group_vars/all/*

# Allow example files inside subdirectories
!group_vars/iosxr/*.example
!group_vars/iosxe/*.example
!group_vars/all/*.example

# Ignore all host_vars contents
host_vars/*

# Allow example templates through
!host_vars/*.example

# Ignore all inventory files
inventory/*

# Allow example inventory files through
!inventory/*.example

# Ignore vars directory - contains site specific data
vars/*

# Allow example vars files through
!vars/*.example

# ==========================================
# TEMPORARY AND GENERATED FILES
# ==========================================
*.retry
*.log
*.bak
*.csv
*.txt
*.save
*.tar.gz